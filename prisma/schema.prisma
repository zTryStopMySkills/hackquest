// HackQuest - Cybersecurity Game
// Prisma Schema — PostgreSQL

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Rank {
  SCRIPT_KIDDIE
  JUNIOR
  PENTESTER
  RED_TEAM
  ELITE_HACKER
  LEGEND
}

enum EloState {
  TILTED
  COLD
  COOLING
  STABLE
  WARMING
  HOT
  ON_FIRE
}

enum CampaignDifficulty {
  HARD
  MEDIUM
  EXPERT
}

enum ProfileTitle {
  NONE
  SECURITY
  HACKER
  THE_ONE
}

enum BannerType {
  NONE
  SECURITY_BLUE
  SECURITY_CYAN
  HACKER_MATRIX
  HACKER_GOLD
  THE_ONE_RED
}

enum Branch {
  WEB_HACKING
  NETWORKS
  CRYPTOGRAPHY
  FORENSICS
  SYSTEMS
  CAMPAIGN
}

enum Difficulty {
  TRIVIAL
  EASY
  MEDIUM
  HARD
  EXPERT
  LEGENDARY
}

enum ChallengeType {
  PUZZLE
  SANDBOX
  CAMPAIGN
  MULTIPLAYER
}

enum MatchMode {
  RACE
  TURNS
  RED_VS_BLUE
  DUEL
}

enum DuelEventType {
  PHASE_COMPLETE
  SABOTAGE_USED
  SABOTAGE_RECEIVED
  FLAG_ATTEMPT
  MATCH_END
}

enum SabotageType {
  NOISE_INJECTION
  HONEYPOT_TRIGGER
  IDS_ALERT
  INTEL_BLACKOUT
}

enum MatchStatus {
  WAITING
  IN_PROGRESS
  FINISHED
}

enum TeamColor {
  RED
  BLUE
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationType {
  WARNING
  REWARD
  SYSTEM
  ADMIN_MESSAGE
}

enum ReportType {
  BUG
  FEEDBACK
  IMPROVEMENT
  CONTENT_ERROR
  OTHER
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum AchievementType {
  CAMPAIGN_HARD
  CAMPAIGN_MEDIUM
  CAMPAIGN_EXPERT
  DAILY_STREAK
  FIRST_BLOOD
  PERFECT_SOLVE
  ELO_MILESTONE
  RANK_UP
  BRANCH_MASTERY
  POKEDEX_COMPLETE
  WIN_STREAK
  SPEED_DEMON
  NO_HINTS
  LEGEND_RANK
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id                 String              @id @default(cuid())
  username           String              @unique
  email              String              @unique
  passwordHash       String
  avatarUrl          String?
  rank               Rank                @default(SCRIPT_KIDDIE)
  points             Int                 @default(0)
  elo                Int                 @default(1000)
  eloState           EloState            @default(STABLE)
  winStreak          Int                 @default(0)
  lossStreak         Int                 @default(0)
  isPremium          Boolean             @default(false)
  campaignDifficulty CampaignDifficulty?
  campaignChapter    Int                 @default(0)
  displayName        String?
  profileTitle       ProfileTitle        @default(NONE)
  bannerType         BannerType          @default(NONE)
  dailyBonusClaimed  DateTime?
  chatNickname       String?
  lastChatMessageAt  DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  lastActiveAt       DateTime            @default(now())

  // Admin fields
  isAdmin            Boolean             @default(false)
  isBanned           Boolean             @default(false)
  banReason          String?
  isIsolated         Boolean             @default(false)
  isolatedUntil      DateTime?

  // Relations
  skillBranches            SkillBranch[]
  challengeAttempts        ChallengeAttempt[]
  matchPlayers             MatchPlayer[]
  campaignProgress         CampaignProgress[]
  pokedexEntries           PokedexEntry[]
  achievements             Achievement[]
  eloHistory               EloHistory[]
  communityMessages        CommunityMessage[]
  notifications            UserNotification[]
  sentPrivateMessages      PrivateMessage[]    @relation("Sender")
  receivedPrivateMessages  PrivateMessage[]    @relation("Recipient")
  adminActionsPerformed    AdminActionLog[]    @relation("AdminActor")
  adminActionsReceived     AdminActionLog[]    @relation("TargetUser")
  reports                  Report[]

  @@index([rank])
  @@index([elo])
  @@index([points])
  @@index([email])
  @@index([username])
}

model SkillBranch {
  id                   String   @id @default(cuid())
  userId               String
  branch               Branch
  level                Int      @default(1)
  xp                   Int      @default(0)
  unlockedChallenges   String[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, branch])
  @@index([userId])
  @@index([branch])
}

model Challenge {
  id               String        @id @default(cuid())
  slug             String        @unique
  title            String
  description      String
  branch           Branch
  difficulty       Difficulty
  type             ChallengeType
  timeLimitSeconds Int
  basePoints       Int           @default(100)
  phases           Json
  flag             String
  briefing         String
  debriefing       String
  hints            Json
  requiredRank     Rank
  isFree           Boolean       @default(true)
  orderInBranch    Int

  // Relations
  attempts ChallengeAttempt[]
  matches  Match[]

  @@index([branch])
  @@index([difficulty])
  @@index([requiredRank])
  @@index([isFree])
  @@index([branch, orderInBranch])
}

model ChallengeAttempt {
  id               String    @id @default(cuid())
  userId           String
  challengeId      String
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  solved           Boolean   @default(false)
  score            Int       @default(0)
  hintsUsed        Int       @default(0)
  perfectSolve     Boolean   @default(false)
  timeSpentSeconds Int       @default(0)
  commandLog       Json      @default("[]")
  reportContent    String?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([challengeId])
  @@index([userId, challengeId])
  @@index([solved])
  @@index([startedAt])
}

model Match {
  id          String      @id @default(cuid())
  mode        MatchMode
  status      MatchStatus @default(WAITING)
  challengeId String
  maxPlayers  Int         @default(5)
  timeLimit   Int
  createdAt   DateTime    @default(now())
  finishedAt  DateTime?

  challenge  Challenge     @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  players    MatchPlayer[]
  duelMatch  DuelMatch?

  @@index([status])
  @@index([mode])
  @@index([challengeId])
  @@index([createdAt])
}

model MatchPlayer {
  id       String    @id @default(cuid())
  matchId  String
  userId   String
  position Int?
  score    Int       @default(0)
  progress Float     @default(0)
  solved   Boolean   @default(false)
  solvedAt DateTime?
  team     TeamColor?

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([userId])
  @@index([team])
}

model CampaignProgress {
  id           String             @id @default(cuid())
  userId       String
  chapterId    Int
  difficulty   CampaignDifficulty
  completedAt  DateTime?
  attempts     Int                @default(0)
  currentPhase Int                @default(0)
  score        Int                @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId, difficulty])
  @@index([userId])
  @@index([chapterId])
  @@index([difficulty])
}

model PokedexEntry {
  id          String   @id @default(cuid())
  userId      String
  techniqueId String
  unlockedAt  DateTime @default(now())
  bestScore   Int      @default(0)
  bestTime    Int      @default(0)
  solvedPerfect Boolean @default(false)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  technique Technique @relation(fields: [techniqueId], references: [id], onDelete: Cascade)

  @@unique([userId, techniqueId])
  @@index([userId])
  @@index([techniqueId])
}

model Technique {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  branch          Branch
  severity        Severity
  cvssScore       Float
  description     String
  howItWorks      String
  realWorldImpact String
  howToDefend     String
  relatedCves     String[]
  requiredRank    Rank

  pokedexEntries PokedexEntry[]

  @@index([branch])
  @@index([severity])
  @@index([requiredRank])
}

model Achievement {
  id          String          @id @default(cuid())
  userId      String
  type        AchievementType
  unlockedAt  DateTime        @default(now())
  metadata    Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@index([type])
  @@index([unlockedAt])
}

model EloHistory {
  id        String   @id @default(cuid())
  userId    String
  elo       Int
  change    Int
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model CommunityMessage {
  id          String   @id @default(cuid())
  userId      String
  displayName String
  content     String   @db.VarChar(300)
  rank        Rank
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
}

model PrivateMessage {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  content     String   @db.VarChar(1000)
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender    User @relation("Sender",    fields: [senderId],    references: [id], onDelete: Cascade)
  recipient User @relation("Recipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([recipientId])
  @@index([createdAt])
  @@index([senderId, recipientId])
}

model UserNotification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.VarChar(1000)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
}

model Report {
  id          String       @id @default(cuid())
  userId      String
  type        ReportType
  title       String       @db.VarChar(120)
  description String       @db.VarChar(2000)
  status      ReportStatus @default(OPEN)
  adminNote   String?      @db.VarChar(500)
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model DuelScenario {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  description  String
  targetType   String   // "web" | "ip" | "base"
  phases       Json
  flag         String
  briefing     String
  hints        Json
  requiredRank Rank

  @@index([requiredRank])
  @@index([targetType])
}

model DuelMatch {
  id          String    @id @default(cuid())
  matchId     String    @unique
  attackerAId String
  attackerBId String
  targetAId   String
  targetBId   String
  winnerId    String?
  eloChangeA  Int       @default(0)
  eloChangeB  Int       @default(0)
  sabotagesA  Int       @default(2)
  sabotagesB  Int       @default(2)
  finishedAt  DateTime?

  match  Match       @relation(fields: [matchId],  references: [id], onDelete: Cascade)
  events DuelEvent[]

  @@index([matchId])
  @@index([attackerAId])
  @@index([attackerBId])
}

model DuelEvent {
  id          String        @id @default(cuid())
  duelMatchId String
  actorId     String
  type        DuelEventType
  payload     Json
  createdAt   DateTime      @default(now())

  duelMatch DuelMatch @relation(fields: [duelMatchId], references: [id], onDelete: Cascade)

  @@index([duelMatchId])
  @@index([actorId])
}

model AdminActionLog {
  id        String   @id @default(cuid())
  adminId   String
  targetId  String
  action    String
  reason    String?
  metadata  Json?
  createdAt DateTime @default(now())

  admin  User @relation("AdminActor", fields: [adminId],  references: [id], onDelete: Cascade)
  target User @relation("TargetUser", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetId])
  @@index([createdAt])
}
